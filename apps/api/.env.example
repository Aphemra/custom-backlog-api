PORT=3001

# mock = use local mock data
# real = call the real IGDB API from the backend
IGDB_SEARCH_MODE=mock

IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# PSNProfiles integration
# false = routes exist but external profile fetches are disabled
# true = backend may request PSNProfiles pages
PSNPROFILES_ENABLED=false
PSNPROFILES_BASE_URL=https://psnprofiles.com
PSNPROFILES_USER_AGENT=CustomBacklogApp/0.1 local-development